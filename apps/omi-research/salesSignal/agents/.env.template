# Copy to .env and fill in real values. Never commit .env.

# vLLM endpoint on AMD MI300X. Include /v1 suffix.
AMD_INFERENCE_URL=http://AMD_IP:8000/v1
# openai SDK requires a non-empty key; any string works against vLLM.
AMD_API_KEY=not-needed
LLAMA_MODEL=meta-llama/Llama-3.1-8B-Instruct

# GoHighLevel — Settings → Integrations → Private → Create Private Integration.
GHL_API_TOKEN=
GHL_LOCATION_ID=
# Optional — required for opportunity creation.
GHL_PIPELINE_ID=
GHL_DEFAULT_STAGE_ID=

# HubSpot — Settings → Integrations → Private Apps → Create → Get Access Token.
HUBSPOT_ACCESS_TOKEN=

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Railway
PORT=8000
