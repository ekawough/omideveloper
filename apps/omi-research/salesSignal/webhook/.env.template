# Copy to .env and fill in real values. Never commit .env.

# Deepgram — $200 free credits at signup. https://deepgram.com
DEEPGRAM_API_KEY=

# Supabase — Pro plan, use the service_role key (bypasses RLS).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for Omi webhook. Set the same value on Omi as ?token=…
WEBHOOK_TOKEN=change-me-to-a-long-random-string

# Agent pipeline — on Railway, use private networking (.railway.internal)
AGENT_PIPELINE_URL=http://agent-pipeline.railway.internal:8000

# Timing knobs (ms)
IDLE_TIMEOUT_MS=30000
MAX_SESSION_MS=1200000

# Railway injects PORT automatically. Fallback for local dev.
PORT=3000
