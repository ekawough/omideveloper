# SOAP Scribe — Environment Variables
#
# HIPAA NOTICE: Before using with real patient data (PHI):
# 1. Sign BAA with Anthropic at console.anthropic.com → Settings → Privacy
# 2. Sign BAA with your cloud provider (Railway, Supabase, etc.)
# 3. Enable HTTPS (Railway does this automatically)
# 4. Enable encryption at rest if adding a database

# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional
PORT=3000
